# Discord Bot Configuration
DISCORD_TOKEN=your_discord_bot_token_here

# Database Configuration (PostgreSQL)
# Either set DATABASE_URL directly, or the individual POSTGRES_* vars below.
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=veka_bot
POSTGRES_USER=veka_user
POSTGRES_PASSWORD=your_secure_password_here
DATABASE_URL=postgresql://veka_user:your_secure_password_here@postgres:5432/veka_bot

# Access Control (comma-separated Discord user IDs)
ADMIN_IDS=123456789,987654321
OWNER_IDS=123456789
FOUNDER_IDS=123456789
STAFF_IDS=
INTERN_IDS=
DONATOR_IDS=
ACTIVE_PRO_IDS=

# Operational alerts channel (Discord channel ID)
ADMIN_ALERT_CHANNEL_ID=

# Radio Configuration
RADIO_STREAM_URL=https://www.youtube.com/watch?v=jfKfPfyJRdk
RADIO_VOICE_CHANNEL_ID=

# RPG / Leaderboard Configuration
LEADERBOARD_CHANNEL_ID=

# Main VEKA server (full functionality available here)
MAIN_GUILD_ID=1088553066334273537
MAIN_SERVER_INVITE_URL=https://discord.gg/veka

# Bot Configuration
BOT_VERSION=1.0.0
LOG_LEVEL=INFO
ENVIRONMENT=development
# ENVIRONMENT=production
