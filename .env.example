# Discord Bot Configuration
DISCORD_TOKEN=your_discord_bot_token_here

# Database Configuration (PostgreSQL)
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=veka_bot
POSTGRES_USER=veka_user
POSTGRES_PASSWORD=your_secure_password_here

# Full Database URL (alternative to individual vars)
DATABASE_URL=postgresql://veka_user:your_secure_password_here@localhost:5432/veka_bot

# MongoDB (Legacy - Remove after migration)
# MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/veka_bot

# Redis (For caching)
REDIS_URL=redis://localhost:6379

# Optional: For external API integrations (Phase 2+)
# OPENAI_API_KEY=your_openai_api_key
# GITHUB_TOKEN=your_github_personal_access_token
# NEWS_API_KEY=your_newsapi_key
# COINGECKO_API_KEY=your_coingecko_key
# ALPHA_VANTAGE_API_KEY=your_alpha_vantage_key
# TWITCH_CLIENT_ID=your_twitch_client_id
# TWITCH_CLIENT_SECRET=your_twitch_client_secret
# YOUTUBE_API_KEY=your_youtube_api_key

# Bot Configuration
BOT_PREFIX=!
LOG_LEVEL=INFO

# Feature Flags (Enable/Disable features)
ENABLE_MENTORSHIP=true
ENABLE_QUIZZES=true
ENABLE_RSS_FEEDS=true
ENABLE_LEADERBOARD=true
ENABLE_WORKSHOPS=true
ENABLE_PORTFOLIO=true
ENABLE_GAMIFICATION=true

# Admin Configuration
ADMIN_USER_IDS=123456789,987654321

# Environment
ENVIRONMENT=development
# ENVIRONMENT=production
